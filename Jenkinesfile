pipeline {
  agent any

  stages {

    stage('Clone') {
      steps {
        git url: 'https://github.com/MohammedAlishan/jenkins-simple-demo.git',
            branch: 'main'
      }
    }

    stage('Check Python Version') {
      steps {
        sh 'python3 --version'
      }
    }

    stage('Run Python Script') {
      steps {
        sh 'python3 one.py'
      }
    }

  }
}
